# === COPY THÀNH ".env" RỒI ĐIỀN (KHÔNG commit .env lên GitHub) ===

# --- Telegram ---
BOT_TOKEN=
ADMIN_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=         # chuỗi bí mật tùy đặt (chống giả webhook)

# --- Sepay (để trống = chế độ MANUAL, admin tự /confirm) ---
SEPAY_API_KEY=

# --- Ngân hàng nhận tiền (khuyến nghị MB Bank) ---
BANK_ACCOUNT=
BANK_NAME=MB Bank
BANK_CODE=MB                      # mã VietQR: MB, VCB, TCB, ACB...
ACCOUNT_NAME=

# --- Hạ tầng ---
BASE_URL=                        # https://<project>.up.railway.app (lấy sau khi deploy)

# --- AI (tùy chọn). Để trống -> bot chạy không AI ---
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1     # Groq: https://api.groq.com/openai/v1
LLM_MODEL=gpt-4o-mini                       # Groq: llama-3.3-70b-versatile

# --- Zalo OA (tùy chọn) ---
ZALO_OA_ACCESS_TOKEN=
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_STRICT=0
